# =============================================================================
# Cloud-Native Data Engineering Platform
# Environment Configuration
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=databricks-dbt-pipeline
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# SUPABASE
# =============================================================================
SUPABASE_PROJECT_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# POSTGRESQL DATABASE (SUPABASE)
# =============================================================================
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.vighgvgxeqmpzossxxjr.supabase.co:5432/postgres

# =============================================================================
# JDBC (SPARK)
# =============================================================================
JDBC_URL=jdbc:postgresql://db.vighgvgxeqmpzossxxjr.supabase.co:5432/postgres

# =============================================================================
# SPARK
# =============================================================================
SPARK_APP_NAME=DataEngineeringPipeline
SPARK_MASTER=local[*]

# =============================================================================
# DBT
# =============================================================================
DBT_TARGET=dev
DBT_SCHEMA=gold

# =============================================================================
# FASTAPI
# =============================================================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# =============================================================================
# FRONTEND
# =============================================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# DATA PATHS
# =============================================================================
RAW_DATA_PATH=./data/raw
BRONZE_DATA_PATH=./data/bronze
SILVER_DATA_PATH=./data/silver
GOLD_DATA_PATH=./data/gold

# =============================================================================
# KAGGLE
# =============================================================================
KAGGLE_DATASET=olistbr/brazilian-ecommerce
